{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*.js"],
      "env": {
        "jest": true
      },
      "rules": {
        "no-param-reassign": "off",
        "func-names": "off"
      }
    },
    {
      "files": ["**/__mocks__/**/*.js"],
      "env": {
        "node": true,
        "jest": true
      }
    }
  ]
}
